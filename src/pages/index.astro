---
const siteTitle = "W3Cplus";
const year = new Date().getFullYear();
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="W3Cplus — Coming Soon" />
    <title>{siteTitle}</title>
  </head>
  <body>
    <header>
      <span class="logo">W3Cplus</span>
    </header>

    <main>
      <div class="center">
        <h1>Coming Soon</h1>
        <p class="desc">
          W3Cplus 正在改版中，即将以全新面貌回归。
        </p>
        <p class="desc">
          这次我们聚焦一件事：AI 时代的前端开发，到底该怎么玩。
        </p>
      </div>
    </main>

    <footer>
      <p>&copy; {year} {siteTitle}</p>
    </footer>

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        background: #0a0a0a;
        color: #f0f0f0;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC",
          "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
        -webkit-font-smoothing: antialiased;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      header {
        padding: 24px 32px;
        border-bottom: 1px solid #1a1a1a;
      }

      .logo {
        font-size: 1.1rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: #f0f0f0;
      }

      main {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 24px;
      }

      .center {
        text-align: center;
        max-width: 500px;
      }

      h1 {
        font-size: 3.5rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        margin-bottom: 28px;
        background: linear-gradient(135deg, #f0f0f0 0%, #00ff88 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .desc {
        font-size: 1.05rem;
        color: #888;
        line-height: 1.8;
        margin-bottom: 8px;
      }

      footer {
        padding: 20px 32px;
        border-top: 1px solid #1a1a1a;
        text-align: center;
      }

      footer p {
        font-size: 0.8rem;
        color: #555;
      }

      @media (max-width: 640px) {
        h1 { font-size: 2.4rem; }
        .desc { font-size: 0.95rem; }
      }
    </style>
  </body>
</html>
