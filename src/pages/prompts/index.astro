      }

      .prompt-meta {
        margin-top: 16px;
        padding-top: 16px;
        border-top: 1px solid var(--border);
      }

      .meta-tools {
        font-size: 0.8rem;
        color: var(--muted);
        margin-bottom: 6px;
      }

      .meta-tip {
        font-size: 0.82rem;
        color: var(--muted-2);
      }

      /* CTA */
      .cta {
        padding: 40px 0;
        border-top: 1px solid var(--border);
