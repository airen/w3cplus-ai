      }

      .cta h2 {
        font-size: 1.4rem;
        color: var(--accent);
        margin-bottom: 12px;
      }

      .cta p {
        font-size: 0.95rem;
        color: var(--muted-2);
        margin-bottom: 8px;
      }

      .cta-status {
        color: var(--muted) !important;
        font-size: 0.85rem !important;
      }

      /* Footer */
      footer {
        max-width: 800px;
        margin: 0 auto;
        padding: 30px 24px;
        border-top: 1px solid var(--border);
