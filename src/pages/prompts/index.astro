      }

      .back-link:hover { color: var(--accent); }

      .header-badge {
        font-size: 0.75rem;
        color: var(--accent);
        border: 1px solid var(--accent);
        padding: 2px 10px;
        border-radius: 20px;
      }

      main {
        max-width: 800px;
        margin: 0 auto;
        padding: 0 24px;
      }

      /* Hero */
      .hero { padding: 60px 0 40px; }

      .badge {
        display: inline-block;
        font-size: 0.8rem;
        color: var(--accent);
        border: 1px solid var(--accent);
        padding: 4px 12px;
        border-radius: 20px;
        margin-bottom: 24px;
      }

      .hero h1 {
        font-size: 2.8rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        margin-bottom: 12px;
        background: linear-gradient(135deg, #f0f0f0 0%, #00ff88 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .tagline {
        font-size: 1.2rem;
        color: var(--fg);
        margin-bottom: 8px;
      }

      .slogan { font-size: 0.9rem; color: var(--muted); }

      /* Prompt cards */
      .prompt-list { padding: 20px 0 60px; }

      .prompt-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 24px;
        margin-bottom: 16px;
        transition: border-color 0.2s;
      }

      .prompt-card:hover { border-color: var(--border-hover); }

      .prompt-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 12px;
      }

      .prompt-num {
        font-size: 0.85rem;
        color: var(--muted);
        font-variant-numeric: tabular-nums;
      }

      .prompt-category {
        font-size: 0.7rem;
        padding: 2px 8px;
        border-radius: 4px;
        border: 1px solid;
      }

      .cat-布局 { color: #0a84ff; border-color: #0a84ff; }
      .cat-视觉效果 { color: #bf5af2; border-color: #bf5af2; }
      .cat-动画 { color: #ff9500; border-color: #ff9500; }
      .cat-响应式 { color: #00ff88; border-color: #00ff88; }
      .cat-设计系统 { color: #ff6b6b; border-color: #ff6b6b; }
      .cat-性能 { color: #5ac8fa; border-color: #5ac8fa; }
      .cat-AI\ 专用 { color: #ffd60a; border-color: #ffd60a; }

      .prompt-difficulty {
        font-size: 0.7rem;
        padding: 2px 8px;
        border-radius: 4px;
        color: var(--muted);
        border: 1px solid var(--border);
      }

      .diff-入门 { color: #00ff88; border-color: #333; }
      .diff-进阶 { color: #ff9500; border-color: #333; }
      .diff-高级 { color: #ff6b6b; border-color: #333; }

      .prompt-title {
        font-size: 1.15rem;
        font-weight: 600;
        margin-bottom: 8px;
      }

      .prompt-desc {
        font-size: 0.9rem;
        color: var(--muted-2);
        margin-bottom: 16px;
      }

      .prompt-details summary {
        cursor: pointer;
        font-size: 0.85rem;
        color: var(--accent);
        padding: 8px 0;
        user-select: none;
      }

      .prompt-details summary:hover { text-decoration: underline; }

      .prompt-content { margin-top: 16px; }

      .prompt-content h3 {
        font-size: 0.8rem;
        color: var(--muted);
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      pre {
        background: var(--code-bg);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 16px;
        overflow-x: auto;
      }

      code {
        font-family: "SF Mono", "Fira Code", "JetBrains Mono", monospace;
        font-size: 0.82rem;
        color: #ccc;
        white-space: pre-wrap;
